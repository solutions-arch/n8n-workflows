    {
      "parameters": {
        "jsCode": "// n8n Code node (Node.js)\n// Logic: Bubble sends a single \"Field Name\" and \"Value\" pair.\n// We map that name to the specific Airtable column and update if changed.\n\n// \u2705 MAPPING: Bubble \"Field Name\" -> Actual Airtable Column Name\n// I have included variations based on your prompt and the payload provided.\nconst MAP = {\n  // Bubble sends : Airtable Column\n  \"Name\": \"Client Name\",\n  \"Client Name\": \"Client Name\", // Included because your payload specifically shows \"Client Name\"\n  \n  \"Email\": \"Email\",\n  \n  \"Contact Number\": \"Phone Number\",\n  \"Phone Number\": \"Phone Number\", // Included for safety\n  \n  \"Timezone\": \"Time Zone\", // Note the space in Airtable based on your payload\n  \"Time Zone\": \"Time Zone\",\n  \n  \"Role\": \"Client Role\",\n  \"Client Role\": \"Client Role\"\n};\n\n// ---------- helpers ----------\nfunction normalize(v) {\n  if (v === undefined) return undefined;\n  if (v === null) return null;\n  return String(v).trim();\n}\n\nfunction valuesEqual(a, b) {\n  return normalize(a) === normalize(b);\n}\n\n// ---------- main ----------\nreturn $input.all().flatMap((item) => {\n  const json = item.json;\n  const bubble = json.body ?? {};\n  \n  const recordId = json.id || json[\"Record ID\"] || json.recordId;\n  if (!recordId) return [];\n\n  // 1. Identify which field Bubble wants to update\n  const incomingLabel = bubble[\"Field Name\"]; \n  const incomingValue = bubble[\"Value\"];\n\n  // 2. Find the corresponding Airtable Column Name\n  const airtableField = MAP[incomingLabel];\n\n  // If we don't recognize the field name, stop here.\n  if (!airtableField) {\n    return [];\n  }\n\n  // 3. Compare current Airtable data vs Bubble data\n  const currentVal = json[airtableField];\n  \n  // If values are the same, do nothing (return empty array)\n  if (valuesEqual(currentVal, incomingValue)) {\n    return [];\n  }\n\n  // 4. Prepare the update\n  const fieldsToUpdate = {};\n  fieldsToUpdate[airtableField] = incomingValue;\n\n  return [\n    {\n      json: {\n        recordId,\n        fields: fieldsToUpdate,\n        airtableBody: { fields: fieldsToUpdate }, // Use this in HTTP Request\n        bubble_id: bubble.bubble_id\n      },\n    },\n  ];\n});"
      },
