    {
      "parameters": {
        "jsCode": "const data = $json.body ?? $json;\n\n// IMPORTANT: adjust this if your webhook uses a different key name\nconst recordId =\n  data.recordId ??\n  data.id ??               // sometimes people send id instead of recordId\n  data.record?.id ??\n  null;\n\nconst stpCode = data.stpCode ?? \"-\";\n\nconst status =\n  data.requisitionStatus?.name ??\n  data.requisitionStatus ??\n  \"-\";\n\nconst cancellationReason =\n  data.cancellationReason?.name ??\n  data.cancellationReason ??\n  null;\n\nconst slackMessage =\n  `Hi team. FYI, the requirement *${stpCode}* has been moved to *${status}*.\\n\\n` +\n  `> _${cancellationReason || \"No cancellation reason provided.\"}_\\n\\n` +\n  `Thank you.`;\n\nreturn [\n  {\n    json: {\n      // carry these forward so later nodes can use them\n      recordId,\n      stpCode,\n      status,\n      cancellationReason,\n      slackMessage,\n    },\n  },\n];\n"
      },
