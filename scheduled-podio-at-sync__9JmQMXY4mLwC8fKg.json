    {
      "parameters": {
        "jsCode": "return items.map((inputItem) => {\n  const record = inputItem.json; // Each item IS already one Podio record\n\n  const fields = Array.isArray(record.fields) ? record.fields : [];\n\n  const findField = (label) => fields.find((f) => f.label === label);\n\n  // All calculation/text fields have: values[0].value (a plain string)\n  // Category fields have: values[0].value.text and values[0].value.id\n  // Money fields have: values[0].value (string amount) and values[0].currency\n  // Date fields have: values[0].start_date\n  const getFieldValue = (label) => {\n    const field = findField(label);\n    if (!field || !Array.isArray(field.values) || field.values.length === 0) return null;\n\n    const raw = field.values[0];\n    if (raw === null || raw === undefined) return null;\n\n    // Category type: { value: { id, text, color, status } }\n    if (raw.value && typeof raw.value === 'object' && raw.value.text !== undefined) {\n      return raw.value.text;\n    }\n\n    // Plain string/number value (calculation, text, number)\n    if (raw.value !== undefined && raw.value !== null) {\n      return raw.value;\n    }\n\n    return null;\n  };\n\n  const getFieldId = (label) => {\n    const field = findField(label);\n    if (!field || !Array.isArray(field.values) || field.values.length === 0) return null;\n    const raw = field.values[0];\n    if (raw && raw.value && typeof raw.value === 'object' && raw.value.id !== undefined) {\n      return raw.value.id;\n    }\n    return null;\n  };\n\n  const getMoney = (label) => {\n    const field = findField(label);\n    if (!field || !Array.isArray(field.values) || field.values.length === 0) {\n      return { amount: null, currency: null };\n    }\n    const raw = field.values[0];\n    return {\n      amount: raw.value !== undefined && raw.value !== null && raw.value !== ''\n        ? Number(raw.value)\n        : null,\n      currency: raw.currency || null,\n    };\n  };\n\n  const getDate = (label) => {\n    const field = findField(label);\n    if (!field || !Array.isArray(field.values) || field.values.length === 0) return null;\n    const raw = field.values[0];\n    return raw.start_date || raw.start || raw.end_date || raw.end || null;\n  };\n\n  const stripHtml = (value) => {\n    if (value === null || value === undefined || value === '') return null;\n    return String(value)\n      .replace(/<br\\s*\\/?>/gi, '\\n')\n      .replace(/<\\/p>/gi, '\\n')\n      .replace(/<\\/li>/gi, '\\n')\n      .replace(/<li>/gi, '- ')\n      .replace(/<[^>]*>/g, '')\n      .replace(/&nbsp;/g, ' ')\n      .replace(/&amp;/g, '&')\n      .replace(/&lt;/g, '<')\n      .replace(/&gt;/g, '>')\n      .replace(/\\n{3,}/g, '\\n\\n')\n      .trim() || null;\n  };\n\n  const parseNumber = (value) => {\n    if (value === null || value === undefined || value === '') return null;\n    const cleaned = String(value).replace(/[^0-9.-]+/g, '');\n    if (!cleaned) return null;\n    const parsed = Number(cleaned);\n    return Number.isNaN(parsed) ? null : parsed;\n  };\n\n  const normalizeEmail = (value) => {\n    if (!value) return null;\n    return String(value).trim().toLowerCase();\n  };\n\n  const clientRate = getMoney('Client Rate');\n  const svCurrentRate = getMoney('SV Current Rate');\n\n  const vaEmail = normalizeEmail(getFieldValue('VA Email Address'));\n  const clientEmail = normalizeEmail(getFieldValue('Client Email Address'));\n\n  const matchKey = vaEmail && clientEmail ? `${vaEmail}|${clientEmail}` : null;\n\n  return {\n    json: {\n      'Podio Item ID': record.item_id || null,\n      'App Item ID': record.app_item_id || null,\n      'Revision': record.revision || null,\n      'Created On': record.created_on || null,\n      'Last Event On': record.last_event_on || null,\n      'Title': record.title || null,\n\n      'MVA Record ID': getFieldValue('MVA Record ID'),\n      'Match Key': matchKey,\n\n      'Contractor Full Name': getFieldValue('Contractor Full Name'),\n      'Client Name': getFieldValue('Client Name'),\n      'Company Name': getFieldValue('Company Name'),\n      'Client Email Address': clientEmail,\n      'Client Billing Email Address': getFieldValue('Client Billing Email Address'),\n      'VA Email Address': vaEmail,\n\n      'MVA Record Status': getFieldValue('MVA Record Status'),\n      'MVA Record Status ID': getFieldId('MVA Record Status'),\n\n      'MVA Contract': getFieldValue('MVA Contract'),\n      'MVA Contract ID': getFieldId('MVA Contract'),\n\n      'MVA': parseNumber(getFieldValue('MVA')),\n      'Work Hours': parseNumber(getFieldValue('WorkHours')),\n\n      'Client Rate Amount': clientRate.amount,\n      'Client Rate Currency': clientRate.currency,\n\n      'SV Current Rate Amount': svCurrentRate.amount,\n      'SV Current Rate Currency': svCurrentRate.currency,\n\n      'SV Base Rate Contract': parseNumber(getFieldValue('SV Base Rate (Contract)')),\n\n      'MVA Type': getFieldValue('MVA Type'),\n      'MVA Type ID': getFieldId('MVA Type'),\n\n      'MVA Start Date': getDate('MVA Start Date'),\n      'Work Days': getFieldValue('Work Days'),\n\n      'Rest Day 1': getFieldValue('Rest Day 1'),\n      'Rest Day 1 ID': getFieldId('Rest Day 1'),\n\n      'Rest Day 2': getFieldValue('Rest Day 2'),\n      'Rest Day 2 ID': getFieldId('Rest Day 2'),\n\n      'Start Time': getFieldValue('Start Time'),\n      'End Time': getFieldValue('End Time'),\n\n      'VA Task List': stripHtml(getFieldValue('VA Task List')),\n    },\n  };\n});"
      },
