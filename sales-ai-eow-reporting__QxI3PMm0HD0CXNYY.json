    {
      "parameters": {
        "jsCode": "// Count all strategy call bookings this week (not canceled)\nconst TZ = 'UTC-5';\nconst now = DateTime.now().setZone(TZ);\nconst weekStart = now.startOf('week');\nconst weekEnd = weekStart.plus({ weeks: 1 });\n\nlet count = 0;\n\nfor (const item of $input.all()) {\n  try {\n    const dateStr = String(item.json.Date || '').trim();\n    if (!dateStr) continue;\n\n    let date = DateTime.fromISO(dateStr).setZone(TZ);\n    if (!date.isValid) {\n      date = DateTime.fromFormat(dateStr, 'M/d/yyyy', { zone: TZ });\n    }\n    if (!date.isValid) continue;\n\n    const canceled = item.json['Canceled?'];\n    const isCanceled = (canceled === true || canceled === 'TRUE' || canceled === 'true');\n\n    if (date >= weekStart && date < weekEnd && !isCanceled) {\n      count++;\n    }\n  } catch (e) {}\n}\n\nreturn [{ json: { type: 'total_bookings', count } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        32,
        48
      ],
      "id": "e404e5f7-66a9-4867-81b8-c19896f6a8be",
      "name": "Count all bookings"
    },
    {
      "parameters": {
        "jsCode": "// Count strategy calls without recordings this week\n// and collect their meeting titles\nconst TZ = 'UTC-5';\nconst now = DateTime.now().setZone(TZ);\nconst weekStart = now.startOf('week');\nconst weekEnd = weekStart.plus({ weeks: 1 });\n\nlet count = 0;\nconst titles = [];\n\nfor (const item of $input.all()) {\n  try {\n    const dateStr = String(item.json.Date || '').trim();\n    if (!dateStr) continue;\n\n    let date = DateTime.fromFormat(dateStr, 'M/d/yyyy', { zone: TZ });\n    if (!date.isValid) {\n      date = DateTime.fromISO(dateStr).setZone(TZ);\n    }\n    if (!date.isValid) continue;\n\n    if (date >= weekStart && date < weekEnd) {\n      count++;\n      titles.push(item.json['Meeting Title'] || 'Untitled');\n    }\n  } catch (e) {}\n}\n\nreturn [{ json: { type: 'no_recording', count, titles } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        32,
        240
      ],
      "id": "3e8c4b2d-f3f0-4f0a-92da-20f57a37d5ff",
      "name": "Count without recording"
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        256,
        144
      ],
      "id": "6d9f77b1-d497-4e48-b539-66046b3a6b2e",
      "name": "Merge Counts"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet totalBookings = 0;\nlet noRecording = 0;\nlet missingTitles = [];\n\nfor (const item of items) {\n  if (item.json.type === 'total_bookings') totalBookings = item.json.count;\n  if (item.json.type === 'no_recording') {\n    noRecording = item.json.count;\n    missingTitles = item.json.titles || [];\n  }\n}\n\nconst withRecording = totalBookings - noRecording;\nconst titleList = missingTitles\n  .map(t => `\u2022 ${t.replace('FREE Strategy Call - ', '')}`)\n  .join('\\n');\n\nconst summary = [\n  `*\ud83d\udcca EOW Strategy Calls Report*`,\n  ``,\n  `*Total calls this week: ${totalBookings}*`,\n  ``,\n  `\u2022 \u2705 With recording: ${withRecording}`,\n  `\u2022 \u26a0\ufe0f Missing recording: ${noRecording}`,\n  ``,\n  `*Calls missing recordings:*`,\n  titleList,\n].join('\\n');\n\nreturn [{\n  json: {\n    total_strategy_calls: totalBookings,\n    with_recording: withRecording,\n    without_recording: noRecording,\n    missing_titles: missingTitles,\n    summary\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        144
      ],
